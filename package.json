{
  "name": "sangpum-capture-price",
  "version": "1.2.3",
  "private": true,
  "description": "상품캡처 및 가격조회 — 사진으로 상품을 인식하고 아이템스카우트 시장 데이터를 조회합니다.",
  "scripts": {
    "dev": "node scripts/next-dev-safe.mjs",
    "dev:fresh": "node scripts/next-dev-safe.mjs --fresh",
    "dev:fast": "next dev -p 3000",
    "clean": "node scripts/clean-next.mjs --kill-port --all",
    "prebuild": "node scripts/clean-next.mjs --build",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "vercel:link": "vercel link --yes --scope nutrifarmer-front --project sangpum-capture-price",
    "vercel:deploy": "vercel --prod --yes --scope nutrifarmer-front"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
